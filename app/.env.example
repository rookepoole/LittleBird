PORT=4173
HOST=127.0.0.1
PUBLIC_BASE_URL=http://127.0.0.1:4173
APP_SLUG=little-bird
LITTLE_BIRD_VERSION=0.3.11
# Public GitHub latest-release API URL or a JSON manifest with version/downloadUrl/releaseNotes
LITTLE_BIRD_UPDATE_MANIFEST_URL=https://api.github.com/repos/rookepoole/LittleBird/releases/latest

# Shopify OAuth app
SHOPIFY_CLIENT_ID=your_shopify_client_id
SHOPIFY_CLIENT_SECRET=your_shopify_client_secret
SHOPIFY_SCOPES=read_orders,read_products,read_analytics
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_API_VERSION=2026-01

# Optional Shopify direct-token fallback
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_your_token

# Meta OAuth app
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_SCOPES=ads_read,business_management
META_API_VERSION=v23.0

# Optional Meta fallback or preferred ad account
META_AD_ACCOUNT_ID=123456789012345
META_ACCESS_TOKEN=your_meta_access_token

# TikTok Business OAuth app
TIKTOK_APP_ID=your_tiktok_app_id
TIKTOK_APP_SECRET=your_tiktok_app_secret
TIKTOK_API_VERSION=v1.3

# Optional TikTok fallback or preferred advertiser
TIKTOK_ADVERTISER_ID=1234567890
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token

# Little Bird local open-source LLM
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b
