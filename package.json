{
  "name": "little-bird",
  "version": "0.3.14",
  "description": "Little Bird",
  "main": "electron/main.js",
  "license": "MIT",
  "private": false,
  "scripts": {
    "desktop": "electron .",
    "test:api": "node scripts/redteam-api-check.js",
    "dist:win": "electron-builder --win nsis --x64 --publish never"
  },
  "devDependencies": {
    "electron": "33.4.11",
    "electron-builder": "25.1.8"
  },
  "build": {
    "appId": "com.rookepoole.littlebird",
    "productName": "Little Bird",
    "executableName": "LittleBird",
    "artifactName": "LittleBirdSetup.exe",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "resources/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "app",
        "to": "little-bird-app",
        "filter": [
          "**/*",
          "!**/.env",
          "!**/.little-bird-tokens.json",
          "!**/.little-bird-oauth-state.json"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "publisherName": "Rooke Poole",
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Little Bird",
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "installerHeaderIcon": "resources/icon.ico",
      "deleteAppDataOnUninstall": false,
      "include": "installer/shortcuts.nsh"
    }
  }
}
